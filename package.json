{
  "name": "anon-kit",
  "version": "0.1.2",
  "description": "Mask sensitive data in any Postgres database.",
  "license": "MIT",
  "author": "Mikael Lirbank",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lirbank/anon-kit.git"
  },
  "homepage": "https://github.com/lirbank/anon-kit#readme",
  "bugs": "https://github.com/lirbank/anon-kit/issues",
  "keywords": [
    "postgres",
    "neon",
    "lakebase",
    "anonymization",
    "masking",
    "pii"
  ],
  "type": "module",
  "bin": {
    "anon-kit": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "format:check": "prettier --check .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "build": "bun build src/cli.ts --outdir dist --target node",
    "prepublishOnly": "bun run build",
    "format": "prettier --write .",
    "schema": "bun dev/build-schema.ts && prettier --write anon-kit.schema.json src/strategies/registry.ts",
    "seed": "bun dev/seed.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "postgres": "^3.4.9",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  }
}
